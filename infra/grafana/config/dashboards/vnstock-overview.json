{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "═══ HOST METRICS ═══",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Host RAM Usage",
      "description": "RAM đang dùng vs tổng. Nếu đường Used chạm Total → OOM risk.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used RAM"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total RAM"
        }
      ]
    },
    {
      "title": "CPU %",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "title": "RAM %",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "RAM %"
        }
      ]
    },
    {
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})",
          "legendFormat": "Disk %"
        }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br-.*|docker0\"}[5m])",
          "legendFormat": "RX"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br-.*|docker0\"}[5m])",
          "legendFormat": "TX"
        }
      ]
    },
    {
      "title": "═══ KAFKA PIPELINE ═══",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false
    },
    {
      "title": "Kafka — Consumer Group Lag",
      "description": "Lag = 0 nghĩa là Spark Streaming đã xử lý kịp tất cả messages từ DNSE WebSocket. Đây là chỉ số quan trọng nhất!",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag_sum",
          "legendFormat": "{{group}} / {{topic}}"
        }
      ]
    },
    {
      "title": "Kafka — Messages/sec per Topic",
      "description": "Throughput từng topic. 6 topics: ohlc_stock, ohlc_derivative, ohlc_index, quote, expected_price, security_def",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(kafka_server_brokertopicmetrics_messagesinpersec_count{topic=~\"ohlc.*|quote|expected.*|security.*\"}[5m])",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "title": "═══ CONTAINER RESOURCES ═══",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "title": "Container Memory (Top 10)",
      "description": "RSS memory của các container nặng nhất. Spark workers sẽ chiếm nhiều nhất (~2GB mỗi worker).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "expr": "topk(10, container_memory_rss{name=~\".+\"})",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "Container CPU (VNStock + Kafka + Spark)",
      "description": "CPU usage % các container chính. Spike khi Spark job chạy batch/backfill.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"(vnstock|kafka|spark|redis|trino|airflow).*\"}[5m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "═══ SPARK & SERVING ═══",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "title": "Spark Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "spark_master_workers_count",
          "legendFormat": "Workers"
        }
      ]
    },
    {
      "title": "Spark Active Apps",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "spark_master_apps_count",
          "legendFormat": "Apps"
        }
      ]
    },
    {
      "title": "Redis Memory Usage",
      "description": "Redis chứa tick/quote/secdef real-time. Thường < 50MB cho ~175 mã.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 134217728 },
              { "color": "red", "value": 268435456 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "container_memory_rss{name=\"redis\"}",
          "legendFormat": "Redis RSS"
        }
      ]
    },
    {
      "title": "Container Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(container_memory_rss{name=~\".+\"})",
          "legendFormat": "Running"
        }
      ]
    },
    {
      "title": "Uptime (Host)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "node_time_seconds - node_boot_time_seconds",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "title": "Trino Active Queries",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 27 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "trino_execution_QueryManager_RunningQueries",
          "legendFormat": "Queries"
        }
      ]
    },
    {
      "title": "═══ LOGS (Loki) ═══",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "VNStock Pipeline Logs",
      "description": "Logs real-time từ Producer, Spark, API, Kafka. Lọc ERROR/WARN để debug.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "{job=~\"vnstock-producer|spark|vnstock-api|kafka|airflow\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["vnstock", "overview", "monitoring", "lakehouse"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d"]
  },
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "VNStock Data Lakehouse — Overview",
  "uid": "vnstock-overview",
  "version": 2
}
