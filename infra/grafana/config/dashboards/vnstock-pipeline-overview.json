{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "orange" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "auto" },
      "targets": [
        { "expr": "up{job=\"vnstock-api\"}", "legendFormat": "API", "refId": "A" },
        { "expr": "up{job=\"kafka\"}", "legendFormat": "Kafka", "refId": "B" },
        { "expr": "up{job=\"spark-master\"}", "legendFormat": "Spark", "refId": "C" },
        { "expr": "up{job=\"redis\"}", "legendFormat": "Redis", "refId": "D" },
        { "expr": "up{job=\"minio_cluster\"}", "legendFormat": "MinIO", "refId": "E" },
        { "expr": "up{job=\"trino\"}", "legendFormat": "Trino", "refId": "F" }
      ]
    },
    {
      "title": "Host Resources",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM", "refId": "A" },
        { "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "legendFormat": "Disk", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] },
          "max": 100
        }
      }
    },
    {
      "title": "Redis — Memory / Keys",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value", "textMode": "auto" },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Memory Used", "refId": "A" },
        { "expr": "redis_db_keys{db=\"db0\"}", "legendFormat": "Keys (db0)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Memory Used" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Keys (db0)" }, "properties": [{ "id": "unit", "value": "short" }] }
        ]
      }
    },
    {
      "title": "Spark Workers / Kafka Lag",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value", "textMode": "auto" },
      "targets": [
        { "expr": "count(up{job=\"spark-worker\"} == 1)", "legendFormat": "Spark Workers", "refId": "A" },
        { "expr": "sum(kafka_consumergroup_lag{topic!='__consumer_offsets'})", "legendFormat": "Kafka Total Lag", "refId": "B" }
      ]
    },
    {
      "title": "API — Request Rate & Latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"vnstock-api\"}[1m])) by (path)", "legendFormat": "{{path}} req/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "API — p95 Response Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"vnstock-api\"}[5m])) by (le, path))", "legendFormat": "p95 {{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Kafka — Consumer Lag by Topic",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(kafka_consumergroup_lag{topic!='__consumer_offsets'}) by (topic)", "legendFormat": "{{topic}}", "refId": "A" }
      ]
    },
    {
      "title": "MinIO — Storage per Bucket",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "minio_bucket_usage_total_bytes", "legendFormat": "{{bucket}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Container CPU %",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name=~\"vnstock.*|kafka|spark.*|redis|minio|trino|flink.*\"}[5m]) * 100", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Container Memory",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~\"vnstock.*|kafka|spark.*|redis|minio|trino|flink.*\"}", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Pipeline Errors (Loki)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=~\"vnstock-producer|airflow|flink.*\"} |~ \"ERROR|WARN|CRITICAL|Exception\"", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["vnstock", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "VNStock Pipeline Overview",
  "uid": "vnstock-pipeline-overview",
  "version": 2
}
