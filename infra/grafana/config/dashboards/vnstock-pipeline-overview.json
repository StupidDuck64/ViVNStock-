{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "orange" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "auto" },
      "targets": [
        { "expr": "up{job=\"vnstock-api\"}", "legendFormat": "VNStock API", "refId": "A" },
        { "expr": "up{job=\"kafka\"}", "legendFormat": "Kafka", "refId": "B" },
        { "expr": "up{job=\"spark-master\"}", "legendFormat": "Spark Master", "refId": "C" },
        { "expr": "up{job=\"redis\"}", "legendFormat": "Redis", "refId": "D" },
        { "expr": "up{job=\"minio_cluster\"}", "legendFormat": "MinIO", "refId": "E" },
        { "expr": "up{job=\"postgres\"}", "legendFormat": "Postgres", "refId": "F" },
        { "expr": "up{job=\"airflow\"}", "legendFormat": "Airflow", "refId": "G" },
        { "expr": "up{job=\"trino\"}", "legendFormat": "Trino", "refId": "H" }
      ]
    },
    {
      "title": "VNStock API — Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"vnstock-api\"}[1m])) by (method, path)", "legendFormat": "{{method}} {{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "VNStock API — p95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"vnstock-api\"}[5m])) by (le, path))", "legendFormat": "p95 {{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Kafka — Consumer Group Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kafka_consumergroup_lag{topic!='__consumer_offsets'}", "legendFormat": "{{consumergroup}} / {{topic}} / {{partition}}", "refId": "A" }
      ]
    },
    {
      "title": "Kafka — Messages In (msg/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(kafka_topic_partition_current_offset{topic!='__consumer_offsets'}[5m])) by (topic)", "legendFormat": "{{topic}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "msg/s" } }
    },
    {
      "title": "Spark — Active Executors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(up{job=\"spark-worker\"} == 1)", "legendFormat": "Workers", "refId": "A" }
      ]
    },
    {
      "title": "Redis — Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Used", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 134217728 }, { "color": "red", "value": 268435456 }] },
          "max": 536870912
        }
      }
    },
    {
      "title": "Redis — Keys Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_db_keys{db=\"db0\"}", "legendFormat": "db0 keys", "refId": "A" }
      ]
    },
    {
      "title": "Redis — Ops/sec",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "ops/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "MinIO — Bucket Object Count",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "minio_bucket_usage_object_total", "legendFormat": "{{bucket}}", "refId": "A" }
      ]
    },
    {
      "title": "MinIO — Bucket Size",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "minio_bucket_usage_total_bytes", "legendFormat": "{{bucket}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name=~\"vnstock.*|kafka|spark.*|redis|minio|trino|airflow.*|postgres\"}[5m]) * 100", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~\"vnstock.*|kafka|spark.*|redis|minio|trino|airflow.*|postgres\"}", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Postgres — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "{{datname}} ({{state}})", "refId": "A" }
      ]
    },
    {
      "title": "Host — Disk Usage %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "legendFormat": "/ disk", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] },
          "max": 100
        }
      }
    },
    {
      "title": "Host — RAM Usage %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] },
          "max": 100
        }
      }
    },
    {
      "title": "Logs — VNStock Producer (Loki)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=\"vnstock-producer\"} |~ \"ERROR|WARN|CRITICAL\"", "refId": "A" }
      ]
    },
    {
      "title": "Logs — Airflow (Loki)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 56 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=\"airflow\"} |~ \"ERROR|WARN|CRITICAL\"", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["vnstock", "pipeline", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "VNStock Pipeline Overview",
  "uid": "vnstock-pipeline-overview",
  "version": 1
}
