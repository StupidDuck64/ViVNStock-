      "targets": [
        { "expr": "rate(ClickHouseProfileEvents_InsertedRows[5m])", "legendFormat": "Inserted Rows/s" },
        { "expr": "rate(ClickHouseProfileEvents_InsertedBytes[5m])", "legendFormat": "Inserted Bytes/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 14 },
      "id": 8,
      "title": "ClickHouse Query Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(ClickHouseProfileEvents_Query[5m])", "legendFormat": "Total Queries/s" },
        { "expr": "rate(ClickHouseProfileEvents_SelectQuery[5m])", "legendFormat": "SELECT/s" },
        { "expr": "rate(ClickHouseProfileEvents_InsertQuery[5m])", "legendFormat": "INSERT/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
