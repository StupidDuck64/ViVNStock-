      "title": "ClickHouse Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "ClickHouseMetrics_MemoryTracking", "legendFormat": "Memory Tracking" },
        { "expr": "ClickHouseAsyncMetrics_TotalBytesOfMergeTreeTables", "legendFormat": "MergeTree Total Bytes" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 302,
      "title": "🐘 PostgreSQL — Metadata Store",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "Active Connections" },
        { "expr": "pg_settings_max_connections", "legendFormat": "Max Connections" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 11,
      "title": "PostgreSQL Transaction Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit[5m])", "legendFormat": "Commits/s — {{ datname }}" },
        { "expr": "rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "Rollbacks/s — {{ datname }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 303,
      "title": "⚡ Redis — Cache Layer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 40 },
