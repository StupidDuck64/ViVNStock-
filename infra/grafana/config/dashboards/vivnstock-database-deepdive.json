      "id": 300,
      "title": "🔍 Trino — Query Engine",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Trino Status",
      "type": "stat",
      "targets": [
        { "expr": "up{job=\"trino\"}", "legendFormat": "Trino" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Running Queries",
      "type": "stat",
      "targets": [
        { "expr": "trino_execution_running_queries", "legendFormat": "Running" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Queued Queries",
      "type": "stat",
      "targets": [
        { "expr": "trino_execution_queued_queries", "legendFormat": "Queued" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "title": "Trino JVM Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_bytes_used{job=\"trino\", area=\"heap\"}", "legendFormat": "Heap Used" },
        { "expr": "jvm_memory_bytes_max{job=\"trino\", area=\"heap\"}", "legendFormat": "Heap Max" },
        { "expr": "jvm_memory_bytes_used{job=\"trino\", area=\"nonheap\"}", "legendFormat": "Non-Heap Used" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "title": "Trino Query Execution Time",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(trino_execution_wall_input_data_cpu_time_seconds_total[5m])", "legendFormat": "CPU Time (rate)" },
        { "expr": "rate(trino_execution_executor_pool_size[5m])", "legendFormat": "Executor Pool" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
