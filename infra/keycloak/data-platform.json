  "clients": [
    {
      "clientId": "superset",
      "name": "Apache Superset",
      "description": "Apache Superset OAuth2 Client",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "CHANGE_ME_SUPERSET_SECRET",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "redirectUris": [
        "http://superset:8088/oauth-authorized/keycloak",
        "http://superset:8088/login/",
        "http://superset:8088/",
        "http://localhost:8089/oauth-authorized/keycloak",
        "http://localhost:8089/login/",
        "http://localhost:8089/",
        "https://superset.company.com/oauth-authorized/keycloak",
        "https://superset.company.com/login/",
        "https://superset.company.com/"
      ],
      "webOrigins": [
        "http://superset:8088",
        "http://localhost:8089",
        "https://superset.company.com"
      ],
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email",
