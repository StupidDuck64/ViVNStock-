# Enforce LF line endings for all text files when checked out on any OS.
# This prevents the "exec /entrypoint.sh: no such file or directory" class
# of errors caused by CRLF shebangs being interpreted on Linux containers.

* text=auto eol=lf

# Explicitly force LF for shell scripts, configs, and Dockerfiles
*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.hcl       text eol=lf
*.conf      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.properties text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
Dockerfile* text eol=lf
.env*       text eol=lf
.gitignore  text eol=lf

# Binary files — do not touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.jar  binary
